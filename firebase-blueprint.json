{
  "entities": {
    "Donation": {
      "title": "Donation",
      "description": "Represents a physical material donation in the AspireBridge system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "donationType": { "type": "string", "enum": ["clothing", "jewellery", "books", "educational_supplies", "other", "clothes", "stationery"] },
        "quantity": { "type": "string" },
        "preference": { "type": "string", "enum": ["pickup", "dropoff"] },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed"] },
        "createdAt": { "type": "string" }
      },
      "required": ["fullName", "phone", "city", "donationType", "quantity", "preference", "status", "createdAt"]
    },
    "Volunteer": {
      "title": "Volunteer",
      "description": "Represents a volunteer registration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "age": { "type": "integer" },
        "city": { "type": "string" },
        "institution": { "type": "string" },
        "skills": { "type": "string" },
        "availability": { "type": "string" },
        "whyVolunteer": { "type": "string" },
        "area": { "type": "string", "enum": ["events", "content", "outreach", "teaching", "media", "tech"] },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "declined"] },
        "createdAt": { "type": "string" }
      },
      "required": ["fullName", "email", "phone", "age", "city", "institution", "skills", "availability", "whyVolunteer", "area", "status", "createdAt"]
    },
    "TeamApplication": {
      "title": "TeamApplication",
      "description": "Represents a core committee team application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "age": { "type": "integer" },
        "contact": { "type": "string" },
        "skills": { "type": "string" },
        "experience": { "type": "string" },
        "whyJoin": { "type": "string" },
        "team": { "type": "string" },
        "weeklyHours": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "declined"] },
        "createdAt": { "type": "string" }
      },
      "required": ["fullName", "age", "contact", "skills", "experience", "whyJoin", "team", "weeklyHours", "status", "createdAt"]
    },
    "WorkshopSignup": {
      "title": "WorkshopSignup",
      "description": "Represents a student workshop registration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ageClass": { "type": "string" },
        "institution": { "type": "string" },
        "contactNumber": { "type": "string" },
        "workshopTitle": { "type": "string" },
        "level": { "type": "string", "enum": ["beginner", "intermediate"] },
        "parentContact": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "ageClass", "institution", "contactNumber", "workshopTitle", "level", "createdAt"]
    }
  },
  "firestore": {
    "donations/{donationId}": {
      "schema": "Donation",
      "description": "Collection of physical material donations."
    },
    "volunteers/{volunteerId}": {
      "schema": "Volunteer",
      "description": "Collection of volunteer registrations."
    },
    "teamApplications/{applicationId}": {
      "schema": "TeamApplication",
      "description": "Collection of core committee applications."
    },
    "workshopRegistrations/{registrationId}": {
      "schema": "WorkshopSignup",
      "description": "Collection of student registrations for workshops."
    }
  }
}
